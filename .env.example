# ═══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES - Hospital Management System
# ═══════════════════════════════════════════════════════════════════════════════
# Copier ce fichier en .env.local et remplir les valeurs appropriées

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND - API ENDPOINTS
# ─────────────────────────────────────────────────────────────────────────────

# Gateway principal (Java Spring Boot)
# Contient tous les services: auth, patients, staff, appointments, etc.
REACT_APP_API_URL=http://localhost:8080

# ML2 FastAPI Standalone
# Service indépendant pour les prédictions de maladie cardiaque (Federated Learning)
REACT_APP_ML2_API_URL=http://localhost:8085

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND - BUILD & DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────

# Mode développement/production
NODE_ENV=development

# Debug level
DEBUG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND - JAVA SPRING BOOT (Gateway)
# ─────────────────────────────────────────────────────────────────────────────

# Server Port
SERVER_PORT=8080

# Eureka Discovery Service
EUREKA_SERVER_URL=http://localhost:8761/eureka/

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-here-change-in-production
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# Database (à configurer par service)
DB_URL=jdbc:mysql://localhost:3306/hospital_db
DB_USERNAME=root
DB_PASSWORD=password
DB_DRIVER=com.mysql.cj.jdbc.Driver

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND - ML2 FASTAPI (Standalone)
# ─────────────────────────────────────────────────────────────────────────────

# ML2 Server
ML2_HOST=0.0.0.0
ML2_PORT=8085

# ML2 JWT (doit être identique au backend Java)
ML2_JWT_SECRET=your-256-bit-secret-key-here-change-in-production

# Model Configuration
ML2_MODEL_PATH=./models/global_model.pth
ML2_DATA_PATH=./data/heart_node1.csv

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# Frontend
REACT_APP_LOG_LEVEL=info

# Backend (Spring Boot)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_HOSPITAL=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_CLOUD_GATEWAY=DEBUG

# ─────────────────────────────────────────────────────────────────────────────
# CORS & SECURITY
# ─────────────────────────────────────────────────────────────────────────────

# Allowed Origins (Frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# CORS Allowed Methods
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH

# CORS Allowed Headers
CORS_ALLOWED_HEADERS=*

# Max request body size (MB)
SERVER_TOMCAT_MAX_HTTP_POST_SIZE=10485760

# ─────────────────────────────────────────────────────────────────────────────
# SERVICE REGISTRY (Eureka)
# ─────────────────────────────────────────────────────────────────────────────

# Eureka Server
EUREKA_PORT=8761

# Service Discovery
EUREKA_FETCH_REGISTRY=true
EUREKA_REGISTER_WITH_EUREKA=true

# ─────────────────────────────────────────────────────────────────────────────
# MICROSERVICES PORTS
# ─────────────────────────────────────────────────────────────────────────────

# Auth Service
AUTH_SERVICE_PORT=8081

# Patient Service
PATIENT_SERVICE_PORT=8082

# Staff Service
STAFF_SERVICE_PORT=8083

# Appointment Service
APPOINTMENT_SERVICE_PORT=8084

# Medical Record Service
MEDICAL_RECORD_SERVICE_PORT=8086

# Consultations Service
CONSULTATIONS_SERVICE_PORT=8087

# Users Service
USERS_SERVICE_PORT=8088

# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT & TESTING
# ─────────────────────────────────────────────────────────────────────────────

# Enable H2 database for testing
SPRING_H2_CONSOLE_ENABLED=true

# Mock data loading
LOAD_SAMPLE_DATA=false

# API Documentation (Swagger)
SPRINGDOC_SWAGGER_UI_ENABLED=true
SPRINGDOC_API_DOCS_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════

# 1. Copier ce fichier:
#    cp .env.example .env.local
#
# 2. Mettre à jour les valeurs:
#    - JWT_SECRET: Générer une clé 256-bit sécurisée
#    - DB_URL, DB_USERNAME, DB_PASSWORD: Configuration de votre DB
#    - ML2_JWT_SECRET: Doit être identique à JWT_SECRET
#
# 3. Variables critiques:
#    - REACT_APP_API_URL: URL du Gateway (port 8080)
#    - REACT_APP_ML2_API_URL: URL de ML2 (port 8085)
#    - JWT_SECRET: Doit être identique entre backend et ML2
#
# 4. Pour le développement local:
#    - Frontend sur port 3000
#    - Gateway sur port 8080
#    - ML2 sur port 8085
#    - Eureka sur port 8761

# ═══════════════════════════════════════════════════════════════════════════════
# SÉCURITÉ - À NE PAS COMMETTRE
# ═══════════════════════════════════════════════════════════════════════════════

# ⚠️ Ne JAMAIS commettre .env.local en production
# ⚠️ Générer des clés JWT sécurisées (min 256-bit)
# ⚠️ Changer les mots de passe par défaut
# ⚠️ Utiliser HTTPS en production
# ⚠️ Restreindre CORS_ALLOWED_ORIGINS en production
# ⚠️ Utiliser des variables d'environnement sécurisées (AWS Secrets Manager, etc.)

# ═══════════════════════════════════════════════════════════════════════════════
# GÉNÉRATION DE CLÉS JWT
# ═══════════════════════════════════════════════════════════════════════════════

# Générer une clé 256-bit sécurisée (macOS/Linux):
# openssl rand -base64 32

# Exemple de sortie:
# aBcDeFgHiJkLmNoPqRsTuVwXyZ0123456789+/=

# ═══════════════════════════════════════════════════════════════════════════════
